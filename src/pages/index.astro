						</h1>
					</div>
				</div>

				<aside class="relative min-h-[880px] overflow-hidden bg-neutral-950 lg:row-span-2">
					<div class="absolute left-4 top-4 z-10 flex gap-2">
						<span class="h-3 w-3 rounded-full bg-white"></span>
						<span class="h-3 w-3 rounded-full bg-neutral-500"></span>
						<span class="h-3 w-3 rounded-full bg-neutral-500"></span>
					</div>
					<div class="absolute inset-x-8 top-16 h-px bg-white/15"></div>
					<div class="absolute bottom-24 left-8 top-16 w-px bg-white/15"></div>
					<div class="absolute bottom-24 right-8 top-16 w-px bg-white/15"></div>
					<img src={portrait.src} alt="" class="absolute left-1/2 top-1/2 w-[1120px] max-w-none -translate-x-1/2 -translate-y-1/2 grayscale opacity-10 blur-[1px] contrast-125" />
					<img src={portrait.src} alt="Illustrated portrait of Phi Hung" class="absolute left-1/2 top-1/2 w-[860px] max-w-[76%] -translate-x-1/2 -translate-y-[46%] grayscale contrast-125" />
					<div class="absolute bottom-0 left-0 right-0 grid grid-cols-3 bg-black/80 text-center backdrop-blur">
						<div class="p-4">
							<p class="text-3xl font-black">UI</p>
							<p class="mono mt-1 text-[10px] uppercase tracking-[0.18em] text-neutral-500">Focus</p>
						</div>
						<div class="p-4">
							<p class="text-3xl font-black">WEB</p>
							<p class="mono mt-1 text-[10px] uppercase tracking-[0.18em] text-neutral-500">Build</p>
						</div>
						<div class="p-4">
							<p class="text-3xl font-black">UX</p>
							<p class="mono mt-1 text-[10px] uppercase tracking-[0.18em] text-neutral-500">Intent</p>
						</div>
					</div>
				</aside>

				<div class="relative bg-neutral-950/70 p-5 lg:-mt-8 lg:rotate-[-2deg]">
					<p class="mono text-xs uppercase tracking-[0.24em] text-neutral-500">Vietnam / Open to frontend roles</p>
