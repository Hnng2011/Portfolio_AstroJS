					</p>
				</div>

				<div class="relative overflow-hidden p-5 lg:-mt-8 lg:rotate-[3deg]">
					<p data-word-reveal="tilt" class="stroke-title text-5xl font-black uppercase leading-none opacity-50 sm:text-6xl">No Safe Zone</p>
				</div>
			</div>
		</section>

		<div class="bg-white py-4 text-black">
			<div class="marquee flex w-[200%] gap-10 whitespace-nowrap text-4xl font-black uppercase leading-none sm:text-7xl">
				<span>React / Next.js / TailwindCSS / TypeScript / Web3 / Supabase /</span>
				<span>React / Next.js / TailwindCSS / TypeScript / Web3 / Supabase /</span>
			</div>
		</div>

		<section id="work" class="mx-auto max-w-[1520px] px-4 py-20 sm:px-6 lg:px-8">
			<div class="mb-8 grid gap-6 lg:grid-cols-[0.55fr_1.45fr]">
				<p class="mono text-xs uppercase tracking-[0.28em] text-neutral-500">Selected work</p>
				<h2 data-word-reveal="slice" class="text-[clamp(3rem,8vw,8.5rem)] font-black uppercase leading-[0.86]">
					Real<br />project work.
				</h2>
			</div>

			<div class="space-y-8 lg:space-y-6">
				{projects.map((project, index) => (
					<article class={`project-card ${index % 2 === 0 ? 'project-card-odd' : 'project-card-even'} group relative grid min-h-[500px] border border-white/10 bg-neutral-950 transition duration-300 hover:z-20 hover:bg-white hover:text-black lg:min-h-[360px]`}>
