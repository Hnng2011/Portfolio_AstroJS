---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import portrait from '../../handrawn-cartoon-style--a-thoughtful-young-man-sit.svg';

const projects = [
	{
		index: '01',
		title: 'Offer Module',
		type: 'Frontend Engineer / TGM Research',
		year: 'Jun 2025 - Present',
		summary: 'Internal pricing and market configuration tools with dynamic forms, Redux decoupling, caching, Vitest, Playwright, and a new Vite + Tailwind + shadcn external portal.',
		tags: ['React', 'Turborepo', 'Zustand'],
		status: 'Live Project',
	},
	{
		index: '02',
		title: 'Formo',
		type: 'Full-stack Developer / Web3 analytics',
		year: 'Feb 2025 - Jun 2025',
		summary: 'A Web3 analytics and form-building platform using Next.js, Express, Supabase, Tinybird, Radix UI, TailwindCSS, Web3 integrations, Slack API, Google APIs, and Paddle.',
		tags: ['Next.js', 'Supabase', 'Web3'],
		url: 'https://formo.so/',
	},
	{
		index: '03',
		title: 'Jigger Mixology',
		type: 'F&B consulting website',
		year: 'Independent project',
		summary: 'A live service website for Jigger Mixology covering cafe setup, beverage training, F&B consulting, service catalogues, and featured projects.',
		tags: ['Website', 'F&B', 'Service UX'],
		url: 'https://jiggermixology.com/',
	},
	{
		index: '04',
		title: 'NYMUSICKR',
		type: 'Frontend Engineer / Burning Bros',
		year: 'Sep 2024 - Feb 2025',
		summary: 'A music commerce web app for albums, fan clubs, and events, built while deepening Remix, SSR optimization, Headless UI, Git workflow, Jira, and Slack collaboration.',
		tags: ['Remix', 'SSR', 'Frontend'],
		url: 'https://nymusickr.com/',
	},
	{
		index: '05',
		title: 'Ubiw',
		type: 'Frontend Engineer / Web3 DApp',
		year: 'Jan 2024 - Jul 2024',
		summary: 'An online content-sharing DApp connecting Web2 users to Web3 through Particle Network account abstraction, social login, ZK Email, Matrix, Cinny, and Synapse.',
		tags: ['DApp', 'Particle', 'ZK Email'],
		status: 'Project Shutdown',
	},
	{
		index: '06',
		title: 'Boxx Circle',
		type: 'Frontend Engineer / Private product',
		year: 'Sep 2023 - Feb 2024',
		summary: 'A recycling-box ecosystem with user and restaurant apps, admin workflows, reusable React + MUI component packages, Capacitor mobile builds, Storybook, and Supabase.',
		tags: ['React', 'MUI', 'Capacitor'],
		status: 'Project Shutdown',
	},
	{
		index: '07',
		title: 'Splitting Me',
		type: 'Frontend Engineer / Outsource',
		year: 'Aug 2023 - Sep 2023',
		summary: 'A Web3 marketplace flow for NFT, token, and real-estate uploads, using React, REST APIs, Wagmi, Ethers.js, Rainbow Kit, IPFS upload, and NFT minting.',
		tags: ['React', 'Wagmi', 'IPFS'],
		status: 'Project Shutdown',
	},
];

const experiences = [
	{
		role: 'Frontend Developer',
		company: 'TGM Research',
		period: 'Jul 2025 - Present',
		detail: 'Refactor legacy code, ship new frontend features, resolve production issues, and contribute product solutions in brainstorming sessions.',
	},
	{
		role: 'Frontend Engineer',
		company: 'Ubiwdotspace - Outsource team',
		period: 'Apr 2024 - Present',
		detail: 'Receive outsource tasks, design UI/UX for web apps, implement frontend screens, test flows, and deploy releases.',
	},
	{
		role: 'Software Engineer',
		company: 'Formo',
		period: 'Feb 2025 - Jun 2025',
		detail: 'Built a full-stack Web3 analytics and form platform with scalable data, real-time analytics, payment, access control, and multi-service consistency.',
	},
	{
		role: 'Software Engineer',
		company: 'Burning Bros',
		period: 'Aug 2024 - Feb 2025',
		detail: 'Improved localization, responsive UI, legacy migration, production stability, and collaboration with UX/UI teams.',
	},
	{
		role: 'Frontend',
		company: 'AZ Solution',
		period: 'Sep 2023 - Feb 2024',
		detail: 'Created reusable React components, improved responsive UI, supported localization, code review, customer feedback, testing, and deployment.',
	},
];
---

<Layout>
	<div class="noise"></div>
	<main class="min-h-screen overflow-hidden text-neutral-50">
		<section id="top" class="relative mx-auto min-h-screen max-w-[1520px] px-4 pb-12 pt-8 sm:px-6 lg:px-8">
