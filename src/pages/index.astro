		<section id="process" class="mx-auto max-w-[1520px] px-4 py-20 sm:px-6 lg:px-8">
			<div class="grid gap-10 lg:grid-cols-[1fr_1fr]">
				<div>
					<p class="mono mb-6 text-xs uppercase tracking-[0.28em] text-neutral-500">Work experience</p>
					<h2 data-word-reveal="slice" class="text-[clamp(3.5rem,9vw,9rem)] font-black uppercase leading-[0.82]">Real product teams.</h2>
				</div>
				<div class="space-y-10">
					{experiences.map((item, index) => (
						<article class="grid gap-4 py-2 sm:grid-cols-[0.2fr_0.8fr]">
							<p class="mono text-sm text-neutral-500">{String(index + 1).padStart(2, '0')}</p>
							<div>
								<p class="mono mb-3 text-xs uppercase tracking-[0.22em] text-neutral-500">{item.period}</p>
								<h3 data-word-reveal="fade" class="text-3xl font-black uppercase leading-none">{item.role}</h3>
								<p class="mt-1 text-xl text-neutral-400">{item.company}</p>
								<p class="mt-4 text-xl leading-snug text-neutral-300">{item.detail}</p>
							</div>
						</article>
					))}
