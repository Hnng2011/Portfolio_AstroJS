						</div>
						<div class="project-summary flex flex-col justify-between gap-8 border-t border-white/10 p-5 lg:min-h-[360px] lg:border-t-0">
							<p class="max-w-2xl text-xl leading-snug text-neutral-300 group-hover:text-neutral-800">{project.summary}</p>
							<div class="flex max-w-full flex-nowrap gap-2 overflow-x-auto pb-1">
								{project.tags.map((tag) => (
									<span class="shrink-0 whitespace-nowrap border border-white/15 px-3 py-2 text-xs uppercase tracking-[0.16em] text-neutral-400 group-hover:border-black/20 group-hover:text-neutral-800">
										{tag}
									</span>
								))}
								{project.url ? (
									<a href={project.url} target="_blank" rel="noreferrer" class="shrink-0 whitespace-nowrap bg-white px-3 py-2 text-xs uppercase tracking-[0.16em] text-black group-hover:bg-black group-hover:text-white">
										Live Link
									</a>
								) : (
									<span class="shrink-0 whitespace-nowrap bg-neutral-800 px-3 py-2 text-xs uppercase tracking-[0.16em] text-neutral-300 group-hover:bg-black group-hover:text-white">
										{project.status}
