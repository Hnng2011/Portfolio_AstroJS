		</section>

		<section class="relative overflow-hidden bg-neutral-100 text-black">
			<div class="mx-auto max-w-[1520px] px-4 py-24 sm:px-6 lg:px-8">
				<p class="mono mb-8 text-xs uppercase tracking-[0.42em] text-neutral-500">Skills Collection</p>
				<div class="grid min-h-[760px] gap-y-8 md:grid-cols-2 md:gap-x-8 lg:grid-cols-12 lg:grid-rows-[auto_auto_auto_auto_auto_auto_auto] lg:gap-y-8">
					<div class="md:col-span-1 lg:col-span-7 lg:row-span-2">
						<p data-word-reveal="stack" class="text-[clamp(4.6rem,11vw,11rem)] font-black uppercase leading-[0.76]">
							React<br />Frontend
						</p>
					</div>
					<div class="md:col-span-1 lg:col-span-3 lg:col-start-8 lg:row-start-1 lg:pt-10">
						<p data-word-reveal="ghost" class="text-right text-[clamp(3.6rem,7vw,6.5rem)] font-black uppercase leading-[0.82] text-neutral-500">
							Web3
						</p>
					</div>

					<div class="lg:col-span-4 lg:row-start-3">
						<p data-word-reveal="scatter" class="-rotate-3 text-3xl font-black uppercase leading-none sm:text-5xl">Next.js Apps</p>
					</div>
					<div class="lg:col-span-4 lg:col-start-6 lg:row-start-3">
						<p data-word-reveal="scatter" class="rotate-2 text-3xl font-black uppercase leading-none sm:text-5xl">Tailwind UI</p>
					</div>
					<div class="lg:col-span-5 lg:col-start-2 lg:row-start-4">
						<p data-word-reveal="scatter" class="rotate-3 text-3xl font-black uppercase leading-none sm:text-5xl">TypeScript</p>
					</div>
					<div class="lg:col-span-5 lg:col-start-8 lg:row-start-4">
						<p data-word-reveal="scatter" class="-rotate-2 text-right text-3xl font-black uppercase leading-none sm:text-5xl">Supabase</p>
					</div>

					<div class="lg:col-span-4 lg:col-start-3 lg:row-start-5">
						<p data-word-reveal="pop" class="-rotate-2 text-4xl font-black uppercase leading-none sm:text-6xl">MUI + Radix</p>
					</div>
					<div class="lg:col-span-3 lg:col-start-8 lg:row-start-5">
						<p data-word-reveal="pop" class="rotate-2 text-right text-4xl font-black uppercase leading-none sm:text-6xl">Zustand</p>
					</div>
					<div class="lg:col-span-3 lg:col-start-4 lg:row-start-6">
						<p data-word-reveal="scatter" class="rotate-3 text-3xl font-black uppercase leading-none sm:text-4xl">shadcn/ui</p>
					</div>
					<div class="lg:col-span-3 lg:col-start-7 lg:row-start-6">
						<p data-word-reveal="scatter" class="-rotate-2 text-3xl font-black uppercase leading-none sm:text-4xl">Playwright</p>
					</div>
					<div class="lg:col-span-2 lg:col-start-9 lg:row-start-7">
						<p data-word-reveal="scatter" class="rotate-2 text-3xl font-black uppercase leading-none sm:text-4xl">Wagmi</p>
					</div>
					<div class="lg:col-span-2 lg:col-start-11 lg:row-start-7">
						<p data-word-reveal="scatter" class="-rotate-3 text-right text-3xl font-black uppercase leading-none sm:text-4xl">AppKit</p>
					</div>
					<div class="md:col-span-2 lg:col-span-4 lg:col-start-1 lg:row-start-7 lg:self-end">
						<p data-word-reveal="outline" class="text-[clamp(3.4rem,6vw,6rem)] font-black uppercase leading-[0.78] text-transparent [-webkit-text-stroke:2px_#111]">
							No Pain<br />No Gain
