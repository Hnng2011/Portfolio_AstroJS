			</div>
		</section>

		<footer id="contact">
			<div class="mx-auto grid max-w-[1520px] gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1.2fr_0.8fr] lg:px-8">
				<h2 data-word-reveal="footer" class="text-5xl font-black uppercase leading-none sm:text-8xl">Frontend engineer building sharp Web2 and Web3 interfaces.</h2>
				<div class="flex flex-col justify-between gap-8">
					<p class="text-xl leading-snug text-neutral-300">Based in Vietnam. English working proficiency. Bachelor of Information Technology, Ho Chi Minh University of Science.</p>
					<span class="inline-flex w-fit bg-white px-5 py-3 text-sm uppercase tracking-[0.2em] text-black">
						luphihung111@gmail.com
					</span>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	const splitWords = (element) => {
		const walker = document.createTreeWalker(element, NodeFilter.SHOW_TEXT, {
			acceptNode(node) {
				if (!node.textContent?.trim()) return NodeFilter.FILTER_REJECT;
				if (node.parentElement?.closest('.word-clip')) return NodeFilter.FILTER_REJECT;
				return NodeFilter.FILTER_ACCEPT;
			},
		});
		const nodes = [];

		while (walker.nextNode()) {
			nodes.push(walker.currentNode);
		}

		nodes.forEach((node) => {
			const fragment = document.createDocumentFragment();
			const parts = node.textContent?.split(/(\s+)/) ?? [];

			parts.forEach((part) => {
				if (!part) return;

				if (/^\s+$/.test(part)) {
					fragment.append(document.createTextNode(part));
					return;
				}

				const clip = document.createElement('span');
				const core = document.createElement('span');
				clip.className = 'word-clip';
				core.className = 'word-core';
				core.textContent = part;
				clip.append(core);
				fragment.append(clip);
			});

			node.replaceWith(fragment);
		});

		return Array.from(element.querySelectorAll('.word-core'));
	};

	const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	const variants = {
		hero: {
			from: { opacity: 0, yPercent: 145, rotate: -10, skewX: -10, scaleY: 1.24 },
			to: { duration: 1, ease: 'expo.out', stagger: 0.055 },
		},
		fade: {
			from: { opacity: 0, yPercent: 70, filter: 'blur(10px)' },
			to: { duration: 0.85, ease: 'power3.out', stagger: 0.025, filter: 'blur(0px)' },
		},
		tilt: {
			from: { opacity: 0, xPercent: -18, yPercent: 70, rotate: 12 },
			to: { duration: 0.95, ease: 'back.out(1.7)', stagger: 0.045 },
		},
		slice: {
			from: { opacity: 0, xPercent: -42, skewX: 18, scaleX: 0.82 },
			to: { duration: 0.9, ease: 'power4.out', stagger: 0.04 },
		},
		'work-left': {
			from: { opacity: 0, xPercent: -24, yPercent: 85, rotate: -7, scaleY: 1.14 },
			to: { duration: 0.85, ease: 'power4.out', stagger: 0.035 },
		},
		'work-right': {
			from: { opacity: 0, xPercent: 24, yPercent: 85, rotate: 7, scaleY: 1.14 },
			to: { duration: 0.85, ease: 'power4.out', stagger: { each: 0.035, from: 'end' } },
		},
		stack: {
			from: { opacity: 0, yPercent: 130, rotateX: -58, transformPerspective: 700 },
			to: { duration: 0.95, ease: 'expo.out', stagger: 0.06 },
		},
		ghost: {
			from: { opacity: 0, xPercent: 16, scale: 1.24, filter: 'blur(14px)' },
			to: { duration: 1.05, ease: 'power3.out', stagger: 0.05, filter: 'blur(0px)' },
		},
		scatter: {
			from: {
				opacity: 0,
				x: (index) => [-34, 28, -18, 22][index % 4],
				y: (index) => [26, -18, 34, -22][index % 4],
				rotate: (index) => [-15, 10, -8, 14][index % 4],
			},
			to: { duration: 0.75, ease: 'back.out(1.9)', stagger: 0.03 },
		},
		pop: {
			from: { opacity: 0, scale: 0.42, rotate: -8 },
			to: { duration: 0.75, ease: 'back.out(2.4)', stagger: 0.04 },
		},
		outline: {
			from: { opacity: 0, yPercent: 80, scaleX: 1.2, letterSpacing: '0.08em' },
			to: { duration: 0.95, ease: 'power4.out', stagger: 0.04, letterSpacing: '0em' },
		},
		footer: {
			from: { opacity: 0, yPercent: 120, rotate: -4, scaleY: 1.2 },
			to: { duration: 1.05, ease: 'expo.out', stagger: 0.045 },
		},
	};

	document.querySelectorAll('[data-word-reveal]').forEach((element, elementIndex) => {
		const words = splitWords(element);
		if (!words.length) return;

		if (reduceMotion) {
			gsap.set(words, { clearProps: 'all', opacity: 1 });
			return;
		}

		const name = element.getAttribute('data-word-reveal') || 'hero';
		const variant = variants[name] || variants.hero;
		const fallbackStagger = {
			each: 0.035,
			from: elementIndex % 2 ? 'end' : 'start',
		};

		gsap.fromTo(
			words,
			variant.from,
			{
				opacity: 1,
				x: 0,
				xPercent: 0,
				y: 0,
				yPercent: 0,
				rotate: 0,
				rotateX: 0,
				skewX: 0,
				scale: 1,
				scaleX: 1,
				scaleY: 1,
				...variant.to,
				stagger: variant.to.stagger || fallbackStagger,
				scrollTrigger: {
					trigger: element,
					start: 'top 88%',
					once: true,
				},
			}
		);
	});
</script>
